# Optional: Google Gemini free-tier key from https://aistudio.google.com/apikey
# The app works without this key (local analysis + charts still run).
# Never upload the real key to GitHub.
GEMINI_API_KEY=paste-your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# App settings
UPLOAD_DIR=data/uploads
API_HOST=0.0.0.0
API_PORT=8010
